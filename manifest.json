{
  "manifest_version": 3,
  "name": "RequestLab",
  "version": "1.0.0",
  "description": "Intercept, modify, and analyze HTTP requests for API debugging and reverse engineering.",
  "permissions": [
    "debugger",
    "webRequest",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "storage",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "devtools_page": "devtools/devtools.html",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/icon.svg"
    },
    "default_title": "RequestLab"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "128": "icons/icon.svg"
  }
}
